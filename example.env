# Local backing-service defaults used by docker-compose.yml.
# These are safe demo defaults so `cp example.env .env && docker compose up -d`
# works without additional edits.
POSTGRES_USER=streaming
POSTGRES_PASSWORD=streaming
MINIO_ROOT_USER=streamingminio
MINIO_ROOT_PASSWORD=streamingminio123
MONGO_INITDB_ROOT_USERNAME=streaming
MONGO_INITDB_ROOT_PASSWORD=streaming
VAULT_DEV_ROOT_TOKEN_ID=streaming-dev-root
REDIS_PASSWORD=

# Generate these with `bash scripts/local/generate-dev-auth-env.sh` before
# running config-server or user-service directly from Maven.
CONFIG_SERVER_JWT_SECRET_KEY=
USER_SERVICE_JWT_PRIVATE_KEY=
USER_SERVICE_JWT_PUBLIC_KEY=

# Frontend label shown in the broadcast suite and used for demo posture copy
STREAMING_ENVIRONMENT_LABEL='Primary Operations'
STREAMING_PUBLIC_RTSP_URL=

# Splunk Observability settings used by the frontend build/deploy flow and
# the dashboard sync scripts. Fill these in with your own org values before
# building, deploying, or syncing dashboards.
# You can keep them here in .env or export them in your shell instead.
# SPLUNK_ACCESS_TOKEN is the Splunk Observability API token used by dashboard
# sync, sourcemap upload, and the collector bootstrap helper.
# SPLUNK_RUM_ACCESS_TOKEN is the Browser RUM token used by the frontend build
# and runtime browser instrumentation.
# SPLUNK_SOURCEMAP_UPLOAD_TOKEN is optional. Set it only when sourcemap upload
# should use a different token than SPLUNK_ACCESS_TOKEN.
# SPLUNK_DEMO_DASHBOARD_GROUP_ID is optional. Set it only when you want the
# dashboard sync script to update an existing dashboard group instead of
# matching or creating one automatically.
# SPLUNK_VALIDATION_TOKEN is optional. Set it when your dashboard-write token
# cannot read metric data from the Splunk validation API but you still want the
# dashboard sync script to prove the ThousandEyes chart series have live data.
# STREAMING_K8S_NAMESPACE should match the namespace where you deployed the
# demo if you want the dashboard CPU chart to follow the correct workload.
# The collector bootstrap helper also reuses SPLUNK_REALM and SPLUNK_ACCESS_TOKEN
# for the base Splunk OTel Collector install when you choose
# --splunk-otel-mode install-if-missing.
SPLUNK_REALM=us1
SPLUNK_ACCESS_TOKEN=
SPLUNK_RUM_ACCESS_TOKEN=
SPLUNK_SOURCEMAP_UPLOAD_TOKEN=
SPLUNK_VALIDATION_TOKEN=
SPLUNK_RUM_APP_NAME=streaming-app-frontend
SPLUNK_DEPLOYMENT_ENVIRONMENT=streaming-app
SPLUNK_DEMO_DASHBOARD_GROUP_ID=
STREAMING_K8S_NAMESPACE=streaming-service-app

# Optional base Splunk OTel Collector bootstrap settings.
# The canonical deploy flow derives the cluster name from the current kube
# context when SPLUNK_OTEL_CLUSTER_NAME is unset, but setting it explicitly is
# safer when your context names are unstable.
# SPLUNK_OTEL_HELM_CHART_VERSION pins the upstream chart version used by the
# repo-managed install path.
SPLUNK_OTEL_CLUSTER_NAME=
SPLUNK_OTEL_HELM_CHART_VERSION=0.148.0

# Optional PostgreSQL DB monitoring settings for the Splunk OTel Collector.
# These are not consumed by the app deploy script directly. They are here so
# the deploy skill and docs can reuse one set of variable names when you layer
# the PostgreSQL receiver on top of the base collector install.
# Use the shared demo database name `streaming`, not the per-service schema
# names like `demo_content` or `billing`.
# SPLUNK_DB_LOGS_ENABLED is a prompt flag only. PostgreSQL server log
# forwarding is not part of the current repo flow unless you also have Splunk
# Platform access and choose to design that path.
SPLUNK_DBMON_POSTGRES_ENDPOINT=streaming-postgres.streaming-service-app.svc.cluster.local:5432
SPLUNK_DBMON_POSTGRES_DATABASES=streaming
SPLUNK_DBMON_POSTGRES_USERNAME=
SPLUNK_DBMON_POSTGRES_PASSWORD=
SPLUNK_DBMON_ACCESS_TOKEN=
SPLUNK_DBMON_EVENT_ENDPOINT=https://ingest.us1.signalfx.com/v3/event
SPLUNK_DBMON_TLS_INSECURE=true
SPLUNK_DBMON_ENABLE_QUERY_SAMPLES=true
SPLUNK_DBMON_ENABLE_TOP_QUERIES=true
SPLUNK_DB_LOGS_ENABLED=false

# Demo auth settings for the Kubernetes demo user-service.
# Leave DEMO_AUTH_SECRET blank to let the canonical deploy script generate it.
# DEMO_AUTH_PASSWORD defaults to password123 when omitted or blank.
DEMO_AUTH_SECRET=
DEMO_AUTH_PASSWORD=password123

# Optional AWS EKS delay-demo defaults used by scripts/aws/deploy-eks-delay-demo.sh.
# Override these in .env or on the CLI when you want a different region, cluster
# name, router key pair, or local break-glass SSH source CIDR.
AWS_REGION=us-east-1
CLUSTER_NAME=streaming-eks-delay-demo
NAMESPACE=streaming-demo
ROUTER_KEY_NAME=appd-tme-key
ROUTER_KEY_PATH='/Users/alecchamberlain/Desktop/Splunk TME/AppD TME/aws/appd-tme-key.pem'
ROUTER_SSH_CIDR=

# ThousandEyes test automation.
# Fill in the token and object IDs below before creating ThousandEyes tests.
# You can set them here in the repo-root .env or export them in your shell.
# TEAGENT_ACCOUNT_TOKEN is the Enterprise Agent account token used by
# scripts/thousandeyes/deploy-enterprise-agent.sh and the full EKS delay demo.
# THOUSANDEYES_ACCOUNT_GROUP_ID comes from:
#   scripts/thousandeyes/create-rtsp-tests.sh list-orgs
# TE_SOURCE_AGENT_IDS and TE_TARGET_AGENT_ID come from:
#   scripts/thousandeyes/create-rtsp-tests.sh list-agents
# TE_APP_SOURCE_AGENT_IDS is optional. Set it when HTTP/RTSP tests should use
# different source agents than the UDP/RTP media tests.
# TE_MEDIA_SOURCE_AGENT_IDS is optional. Set it when UDP/RTP tests should use
# different source agents than the public HTTP/RTSP tests.
# TE_UDP_TARGET_AGENT_ID is optional. Set it when the UDP media-path test should
# use a different target than the RTP proxy test, for example when you want the
# UDP test to target a Cloud Agent but keep RTP pinned to an Enterprise Agent.
# The repo-global TE_*_TEST_ID values below are for the primary cluster flow.
# scripts/aws/deploy-eks-delay-demo.sh keeps its second-cluster test names and
# IDs in the generated .generated/aws/<cluster>.env state file so it can manage
# a separate ThousandEyes suite and dashboard group.
# Set TE_RTSP_SERVER only when you are using the direct API flow or when the
# Kubernetes wrapper cannot discover the public RTSP hostname automatically.
# Choose one target mode for ThousandEyes tests:
# - local: keep the default svc.cluster.local frontend URLs so same-network
#   Enterprise Agents can test private endpoints
# - external: override the frontend base URL, explicit HTTP test URLs, and
#   RTSP host with public values reachable by outside agents
THOUSANDEYES_BEARER_TOKEN=
THOUSANDEYES_ACCOUNT_GROUP_ID=
TEAGENT_ACCOUNT_TOKEN=
TE_SOURCE_AGENT_IDS=
TE_APP_SOURCE_AGENT_IDS=
TE_MEDIA_SOURCE_AGENT_IDS=
TE_TARGET_AGENT_ID=
TE_UDP_TARGET_AGENT_ID=
# Tests are enabled by default. Set individual TE_*_ENABLED flags to false when
# you want the repo-managed test definitions to exist without consuming
# ThousandEyes utilization.
TE_RTSP_TCP_ENABLED=true
TE_UDP_MEDIA_ENABLED=true
TE_RTP_STREAM_ENABLED=true
TE_TRACE_MAP_ENABLED=true
TE_BROADCAST_ENABLED=true
# Alerts are enabled for all repo ThousandEyes tests by default.
# For booth-specific tuning, keep this true and override individual tests with
# TE_RTSP_TCP_ALERTS_ENABLED, TE_UDP_MEDIA_ALERTS_ENABLED,
# TE_RTP_STREAM_ALERTS_ENABLED, TE_TRACE_MAP_ALERTS_ENABLED, or
# TE_BROADCAST_ALERTS_ENABLED when you only want the public HTTP paths to alert.
TE_ALERTS_ENABLED=true
TE_ALERT_MINIMUM_SOURCES=1
TE_ALERT_NOTIFY_ON_CLEAR=true
THOUSANDEYES_ALERT_EMAIL_RECIPIENTS=
THOUSANDEYES_ALERT_EMAIL_MESSAGE=
THOUSANDEYES_ALERT_NOTIFICATIONS_JSON=
TE_DSCP_ID=0
TE_RTSP_SERVER=
TE_RTSP_PORT=8554
TE_RTSP_TCP_TEST_NAME=RTSP-TCP-8554
TE_RTSP_TCP_TEST_ID=
TE_UDP_MEDIA_TEST_NAME=UDP-Media-Path
TE_UDP_MEDIA_TEST_ID=
TE_RTP_STREAM_TEST_NAME=RTP-Stream-Proxy
TE_RTP_STREAM_TEST_ID=
# Override this to a public URL such as https://demo.example.com in external mode.
TE_DEMO_MONKEY_FRONTEND_BASE_URL=http://streaming-frontend.streaming-service-app.svc.cluster.local
TE_TRACE_MAP_TEST_NAME=aleccham-broadcast-trace-map
TE_TRACE_MAP_TEST_ID=
TE_TRACE_MAP_TEST_URL=http://streaming-frontend.streaming-service-app.svc.cluster.local/api/v1/demo/public/trace-map
TE_BROADCAST_TEST_NAME=aleccham-broadcast-playback
TE_BROADCAST_TEST_ID=
TE_BROADCAST_TEST_URL=http://streaming-frontend.streaming-service-app.svc.cluster.local/api/v1/demo/public/broadcast/live/index.m3u8
TE_A2A_PORT=5004
# Set this to false when TE_UDP_TARGET_AGENT_ID or TE_TARGET_AGENT_ID points at
# a Cloud Agent because ThousandEyes rejects UDP throughput with a Cloud Agent.
TE_A2A_THROUGHPUT_MEASUREMENTS=true
TE_A2A_THROUGHPUT_RATE_MBPS=10
TE_VOICE_PORT=49152
TE_VOICE_CODEC_ID=0

# Broadcast load generator defaults used by scripts/loadgen/deploy-k8s-broadcast-loadgen.sh.
# These values are tuned for the safer booth-default profile we validated in-cluster.
# Override them in .env or in the shell when you want a warmer ramp or a destructive
# stress pass.
LOADGEN_PROFILE=booth
LOADGEN_BASE_URL=http://streaming-frontend.streaming-service-app.svc.cluster.local
LOADGEN_TARGET_VIEWERS=90
LOADGEN_DURATION=10m
LOADGEN_RAMP_UP=2m
LOADGEN_RAMP_DOWN=1m
LOADGEN_SESSION_MIN=90s
LOADGEN_SESSION_MAX=4m
LOADGEN_PAGE_VIEWER_RATIO=0.35
LOADGEN_TRACE_MAP_SESSION_RATIO=0.10
LOADGEN_STATUS_POLL_INTERVAL=5s
LOADGEN_REQUEST_TIMEOUT=15s
LOADGEN_VARIANT_STRATEGY=balanced
LOADGEN_LIVE_EDGE_SEGMENTS=1
LOADGEN_LIVE_EDGE_PARTS=8
LOADGEN_MAX_PLAYBACK_ERRORS=6
LOADGEN_LOG_EVERY=5s

# Optional recurring in-cluster loadgen mode and operator actions.
# LOADGEN_PROFILE can be warmup, booth, stress, or custom.
# LOADGEN_K8S_ACTION can be apply, status, delete, pause, resume, or trigger.
# Leave LOADGEN_K8S_MODE=job for ad hoc runs. Set it to cronjob when you want
# Kubernetes to launch the selected profile on a regular cadence.
LOADGEN_K8S_MODE=job
LOADGEN_K8S_ACTION=apply
LOADGEN_CRONJOB_NAME=broadcast-loadgen-recurring
LOADGEN_CRON_SCHEDULE='*/15 * * * *'
LOADGEN_CRON_CONCURRENCY_POLICY=Forbid
LOADGEN_CRON_SUSPEND=false
LOADGEN_CRON_SUCCESS_HISTORY=1
LOADGEN_CRON_FAILED_HISTORY=2
LOADGEN_TRIGGER_JOB_NAME=

# Protected operator, billing, and commerce load generator defaults used by
# scripts/loadgen/deploy-k8s-operator-billing-loadgen.sh. These values bias
# toward the safer booth profile that exercises Accounts, Payments, Commerce,
# billing events, and selected media-control actions without overwhelming the
# cluster.
LOADGEN_OPERATOR_PROFILE=booth
LOADGEN_OPERATOR_BASE_URL=http://streaming-frontend.streaming-service-app.svc.cluster.local
LOADGEN_OPERATOR_PERSONA=operator
LOADGEN_OPERATOR_DURATION=8m
LOADGEN_OPERATOR_CONCURRENCY=3
LOADGEN_OPERATOR_PAUSE=4s
LOADGEN_OPERATOR_REQUEST_TIMEOUT=15s
LOADGEN_OPERATOR_CUSTOMER_PAGE_SIZE=24
LOADGEN_OPERATOR_BILLING_EVENT_RATIO=0.55
LOADGEN_OPERATOR_PAYMENT_RATIO=0.20
LOADGEN_OPERATOR_PAYMENT_READ_RATIO=0.80
LOADGEN_OPERATOR_COMMERCE_READ_RATIO=0.85
LOADGEN_OPERATOR_ORDER_CREATE_RATIO=0.35
LOADGEN_OPERATOR_ORDER_SETTLE_RATIO=0.35
LOADGEN_OPERATOR_ORDER_COMPLETE_RATIO=0.15
LOADGEN_OPERATOR_RTSP_JOB_RATIO=0.35
LOADGEN_OPERATOR_TAKE_LIVE_RATIO=0.20

# Optional recurring in-cluster mode and operator actions for the protected
# load generator. LOADGEN_OPERATOR_PROFILE can be warmup, booth, stress, or
# custom. LOADGEN_OPERATOR_K8S_ACTION can be apply, status, delete, pause,
# resume, or trigger.
LOADGEN_OPERATOR_K8S_MODE=job
LOADGEN_OPERATOR_K8S_ACTION=apply
LOADGEN_OPERATOR_JOB_NAME=operator-billing-loadgen
LOADGEN_OPERATOR_CRONJOB_NAME=operator-billing-loadgen-recurring
LOADGEN_OPERATOR_CRON_SCHEDULE='*/20 * * * *'
LOADGEN_OPERATOR_CRON_CONCURRENCY_POLICY=Forbid
LOADGEN_OPERATOR_CRON_SUSPEND=false
LOADGEN_OPERATOR_CRON_SUCCESS_HISTORY=1
LOADGEN_OPERATOR_CRON_FAILED_HISTORY=2
LOADGEN_OPERATOR_TRIGGER_JOB_NAME=
